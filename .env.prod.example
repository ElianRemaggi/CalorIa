# CalorIA — Production Environment Variables
# Copy this file to .env.prod and fill in real values
# NEVER commit .env.prod to git

# ── Database (Supabase) ──────────────────────────────────────────────────────
# Get from: Supabase dashboard → Project Settings → Database → Connection string → JDBC
# Use the "Transaction" pooler URI for better connection handling
DATABASE_URL=jdbc:postgresql://db.xxxxxxxxxxxx.supabase.co:5432/postgres?sslmode=require
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your-supabase-db-password

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate a secure secret:  openssl rand -base64 64
JWT_SECRET=paste-your-generated-secret-here
JWT_EXPIRATION_MS=3600000

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
# Get from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Use the Web Application client ID
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
