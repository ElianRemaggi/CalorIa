{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://10.0.2.2:8080/api/v1"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://caloria.drinklen.com.ar/api/v1",
        "EXPO_PUBLIC_GOOGLE_CLIENT_ID": "953783966762-5bnejkabgh7a4knrp1l37doa3v7p995l.apps.googleusercontent.com"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://caloria.drinklen.com.ar/api/v1",
        "EXPO_PUBLIC_GOOGLE_CLIENT_ID": "953783966762-5bnejkabgh7a4knrp1l37doa3v7p995l.apps.googleusercontent.com"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-services-key.json",
        "track": "internal"
      }
    }
  }
}
