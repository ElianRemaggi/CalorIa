{
  "name": "caloria-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest --watchAll=false --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --watchAll=false --forceExit --coverage"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect",
      "./jest.setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|date-fns)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.2",
    "@hookform/resolvers": "^3.9.0",
    "@react-native-google-signin/google-signin": "^12.2.1",
    "@tanstack/react-query": "^5.51.1",
    "axios": "^1.7.2",
    "date-fns": "^3.6.0",
    "expo": "~51.0.0",
    "expo-file-system": "~17.0.1",
    "expo-image-picker": "~15.0.7",
    "expo-notifications": "~0.28.0",
    "expo-router": "~3.5.0",
    "expo-secure-store": "~13.0.0",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-hook-form": "^7.52.1",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "zod": "^3.23.8",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.9.0",
    "@types/react": "~18.2.79",
    "@types/react-test-renderer": "^18.3.1",
    "babel-plugin-module-resolver": "^5.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.3",
    "react-test-renderer": "^18.2.0",
    "typescript": "^5.3.3"
  }
}
