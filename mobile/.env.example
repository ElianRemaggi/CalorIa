# CalorIA Mobile — Environment Variables
# For local dev: copy to .env.local (Expo loads this automatically)
# For production: set these in EAS Secrets (eas secret:create)

# Backend API base URL
# Local Android emulator: http://10.0.2.2:8080/api/v1
# Local iOS simulator:    http://localhost:8080/api/v1
# Production:             https://your-railway-app.up.railway.app/api/v1
EXPO_PUBLIC_API_URL=http://10.0.2.2:8080/api/v1

# Google OAuth — Web Client ID (from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
