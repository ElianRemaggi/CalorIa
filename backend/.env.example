# CalorIA Backend — Environment Variables
# Copy this file to .env for local development (never commit .env)

# Spring profile: use "prod" for production deployments
SPRING_PROFILES_ACTIVE=prod

# Database (Supabase PostgreSQL in production)
# Format: jdbc:postgresql://<host>:<port>/<database>?sslmode=require
DATABASE_URL=jdbc:postgresql://localhost:5432/caloria
DATABASE_USERNAME=caloria
DATABASE_PASSWORD=caloria

# JWT — generate a secure random secret (min 32 chars) for production
# Example: openssl rand -base64 64
JWT_SECRET=change-this-to-a-secure-random-secret-at-least-256-bits-long
JWT_EXPIRATION_MS=3600000

# Google OAuth2
# Get this from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
